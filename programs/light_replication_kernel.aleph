# Minimal Protected Kernel
let kernel = palace(4) mediate(vav, system(), light)

# Spawn two protected subprocesses
let proc_a = mediate(aleph, kernel, mem)
let proc_b = mediate(aleph, kernel, shin)

palace(3) proc_a
palace(3) proc_b

d(proc_a, proc_b)
d(proc_a, kernel)
d(proc_b, system())

tier(proc_a)
probe_Ω(proc_a)
