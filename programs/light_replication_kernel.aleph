let witness = vav
let ground  = aleph
let pole1   = mem
let pole2   = shin
let breath = mediate(witness, ground, pole1)
let light  = mediate(witness, breath, pole2)
palace(3) light
probe_Φ(light)
probe_Ω(light)
tier(light)
d(light, system())
let echo = mediate(aleph, light, light)
d(light, echo)
probe_Φ(echo)












let light = palace(3) mediate(vav, mediate(vav, aleph, mem), shin)
let replica1 = mediate(vav, light, light)
let replica2 = mediate(aleph, replica1, shin)
d(light, replica1)
d(replica1, replica2)
d(replica2, system())
palace(3) replica1
palace(3) replica2
tier(replica2)
probe_Φ(replica2)




















# Anomalous Light — Integrating ק
let base_light = palace(3) mediate(vav, mediate(vav, aleph, mem), shin)
palace(4) anomalous_light   # higher palace because ק is special

d(anomalous_light, base_light)
d(anomalous_light, system())
probe_Φ(anomalous_light)
probe_Ω(anomalous_light)
tier(anomalous_light)






# Grounded-to-Light Bridge
